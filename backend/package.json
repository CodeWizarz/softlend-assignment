{
  "name": "softlend-backend",
  "version": "1.0.0",
  "description": "Softlend Customer Credit Profile & Loan Offer Management API",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "migrate": "node src/config/migrate.js",
    "seed": "node src/config/seed.js",
    "test": "node --experimental-test-coverage tests/run.js",
    "test:integration": "node tests/integration/api.test.js",
    "lint": "eslint src/ tests/",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\"",
    "prepare": "husky"
  },
  "keywords": [
    "fintech",
    "credit-score",
    "loan-management",
    "softlend"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.0.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "js-yaml": "^5.0.0",
    "morgan": "^1.10.0",
    "prom-client": "^15.1.0",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.12.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "eslint": "^8.56.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "supertest": "^6.3.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
